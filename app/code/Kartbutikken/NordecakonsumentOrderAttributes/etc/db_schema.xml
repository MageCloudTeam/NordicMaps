<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_order" resource="sales">
        <column name="use_invoice_email" xsi:type="boolean" nullable="false" default="0" comment="Use invoice email address"/>
        <column name="invoice_email" xsi:type="varchar" nullable="true" length="255" comment="Invoice Email Address"/>
        <column name="reference_code" xsi:type="varchar" nullable="true" length="255" comment="Reference Code"/>
    </table>
    <table name="quote" resource="checkout">
        <column name="use_invoice_email" xsi:type="boolean" nullable="false" default="0" comment="Use invoice email address"/>
        <column name="invoice_email" xsi:type="varchar" nullable="true" length="255" comment="Invoice Email Address"/>
        <column name="reference_code" xsi:type="varchar" nullable="true" length="255" comment="Reference Code"/>
    </table>
    <table name="sales_order_grid" resource="sales">
        <column name="use_invoice_email" xsi:type="boolean" nullable="false" default="0" comment="Use invoice email address"/>
        <column name="invoice_email" xsi:type="varchar" nullable="true" length="255" comment="Invoice Email Address"/>
        <column name="reference_code" xsi:type="varchar" nullable="true" length="255" comment="Reference Code"/>
    </table>
</schema>