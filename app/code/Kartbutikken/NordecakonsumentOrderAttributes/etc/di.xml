<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="Magento\Sales\Model\ResourceModel\Order\Grid">
        <arguments>
            <argument name="columns" xsi:type="array">
                <item name="use_invoice_email" xsi:type="string">sales_order.use_invoice_email</item>
                <item name="invoice_email" xsi:type="string">sales_order.invoice_email</item>
                <item name="reference_code" xsi:type="string">sales_order.reference_code</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Magento\Checkout\Model\PaymentInformationManagement">
        <plugin name="Kartbutikken_NordecakonsumentOrderAttributes::before_order"
                type="Kartbutikken\NordecakonsumentOrderAttributes\Plugin\ShippingInformationManagement" sortOrder="10"
                disabled="false"/>
    </type>
    <type name="Magento\Sales\Api\OrderRepositoryInterface">
        <plugin name="Kartbutikken_NordecakonsumentOrderAttributes"
                type="Kartbutikken\NordecakonsumentOrderAttributes\Plugin\OrderGet"/>
    </type>
</config>