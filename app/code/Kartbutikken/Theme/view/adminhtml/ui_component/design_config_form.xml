<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="other_settings">
        <fieldset name="header">
            <field name="header_logo_src" formElement="imageUploader" sortOrder="10">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="backend_model" xsi:type="string">Kartbutikken\Theme\Model\Design\Backend\Logo</item>
                        <item name="notice" xsi:type="string" translate="true">Allowed file types: png, gif, jpg, jpeg, svg</item>
                        <item name="allowedExtensions" xsi:type="string">jpg jpeg gif png svg</item>
                        <item name="sortOrder" xsi:type="number">10</item>
                    </item>
                </argument>
            </field>
            <field name="header_logo_small_src" formElement="imageUploader" sortOrder="20">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="dataType" xsi:type="string">text</item>
                        <item name="dataScope" xsi:type="string">header_logo_small_src</item>
                        <item name="path" xsi:type="string">design/header/header_logo_small_src</item>
                        <item name="backend_model" xsi:type="string">Kartbutikken\Theme\Model\Design\Backend\Logo</item>
                        <item name="label" xsi:type="string" translate="true">Logo Image Small</item>
                        <item name="formElement" xsi:type="string">imageUploader</item>
                        <item name="componentType" xsi:type="string">imageUploader</item>
                        <item name="notice" xsi:type="string" translate="true">Allowed file types: png, gif, jpg, jpeg, svg</item>
                        <item name="maxFileSize" xsi:type="number">2097152</item>
                        <item name="allowedExtensions" xsi:type="string">jpg jpeg gif png svg</item>
                        <item name="sortOrder" xsi:type="number">20</item>
                        <item name="uploaderConfig" xsi:type="array">
                            <item name="url" xsi:type="string">theme/design_config_fileUploader/save</item>
                        </item>
                        <item name="base_url" xsi:type="array">
                            <item name="type" xsi:type="string">media</item>
                            <item name="scope_info" xsi:type="string">1</item>
                            <item name="value" xsi:type="string">logo</item>
                        </item>
                    </item>
                </argument>
            </field>
            <field name="header_logo_width" formElement="input" sortOrder="30">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="sortOrder" xsi:type="number">30</item>
                    </item>
                </argument>
            </field>
            <field name="header_logo_height" formElement="input">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="sortOrder" xsi:type="number">40</item>
                    </item>
                </argument>
            </field>
            <field name="header_logo_alt" formElement="input">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="sortOrder" xsi:type="number">60</item>
                    </item>
                </argument>
            </field>
            <field name="header_logo_slogan" formElement="input" sortOrder="70">
                <settings>
                    <dataType>text</dataType>
                    <label translate="true">Logo Slogan</label>
                    <dataScope>header_logo_slogan</dataScope>
                </settings>
            </field>
            <field name="header_welcome" formElement="input">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="sortOrder" xsi:type="number">80</item>
                    </item>
                </argument>
            </field>
        </fieldset>
    </fieldset>
</form>