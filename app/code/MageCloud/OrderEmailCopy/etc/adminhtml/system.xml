<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="magecloud">
            <label>MageCloud</label>
        </tab>
        <section id="order_email_copy" translate="label" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Order Email Copy Mapping</label>
            <tab>magecloud</tab>
            <resource>MageCloud_OrderEmailCopy::settings</resource>
            <group id="general" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1"
                   showInStore="1">
                <label>Auto order Email Copy</label>
                <field id="module_enabled" translate="label" type="select" sortOrder="10" showInDefault="1"
                       showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="orderemailcopy_rules" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1"
                       showInStore="1">
                    <label>Order Email Copy Rules</label>
                    <frontend_model>MageCloud\OrderEmailCopy\Block\Adminhtml\Form\Field\OrderEmailCopyRule</frontend_model>
                    <backend_model>MageCloud\OrderEmailCopy\Model\SeriesProcess</backend_model>
                </field>
            </group>
        </section>
    </system>
</config>
