            <policy id="connect-src">
                <values>
                    <value id="en.nordicmaps.no" type="host">https://en.nordicmaps.no</value>
                    <value id="www.nordicmaps.no" type="host">https://www.nordicmaps.no/</value>
                    <value id="admi.nordicmaps.no" type="host">https://admi.nordicmaps.no</value>
                </values>
            </policy>
            <policy id="style-src">
                <values>
                    <value id="www.nordicmaps.no" type="host">https://www.nordicmaps.no/</value>
                    <value id="admi.nordicmaps.no" type="host">https://admi.nordicmaps.no</value>
                </values>
            </policy>
        </policies>
</csp_whitelist>
