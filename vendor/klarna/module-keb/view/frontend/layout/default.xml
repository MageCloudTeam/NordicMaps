<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Klarna_Keb::css/button.css" />
    </head>
    <body>
        <referenceBlock name="footer">
            <block class="Klarna\Keb\Block\Footer" name="klarna.keb.footer" template="Klarna_Keb::footer.phtml"/>
        </referenceBlock>
        <referenceContainer name="minicart.addons">
            <block class="Klarna\Keb\Block\Button"
                   name="klarna.keb.button.minicart"
                   template="Klarna_Keb::button_minicart.phtml"
            />
        </referenceContainer>
        <referenceContainer name="cart.summary">
            <block class="Klarna\Keb\Block\Button"
                   name="klarna.keb.button.cart_page"
                   template="Klarna_Keb::button_cart_page.phtml"
                   after="-"
            />
        </referenceContainer>
    </body>
</page>
