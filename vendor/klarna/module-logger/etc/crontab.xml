<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="klarna_core_clean_logs" instance="Klarna\Logger\Cron\CleanLogs" method="execute">
            <schedule>0 0 * * *</schedule>
        </job>
        <job name="klarna_core_update_api_log" instance="Klarna\Logger\Cron\UpdateApiLog" method="execute">
            <schedule>* * * * *</schedule>
        </job>
    </group>
</config>
