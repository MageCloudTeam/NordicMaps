<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="\Magento\Sales\Block\Adminhtml\Order\View">
        <plugin name="Klarna_Kco::addPaymentStatusButton" type="Klarna\Kco\Plugin\AddPaymentStatusButton" />
    </type>
    <type name="Magento\Framework\Notification\MessageList">
        <arguments>
            <argument name="messages" xsi:type="array">
                <item name="klarnaKcoApi" xsi:type="string">Klarna\Kco\Model\System\Message\ApiConfig\Notification</item>
                <item name="klarnaKcoCheckout" xsi:type="string">Klarna\Kco\Model\System\Message\CheckoutConfig\Notification</item>
                <item name="klarnaKcoTarget" xsi:type="string">Klarna\Kco\Model\System\Message\TargetConfig\Notification</item>
                <item name="klarnaKcoDesign" xsi:type="string">Klarna\Kco\Model\System\Message\DesignConfig\Notification</item>
            </argument>
        </arguments>
    </type>
</config>
